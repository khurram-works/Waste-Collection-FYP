// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}


// ==================== ENUMS ====================

enum Role {
  CITIZEN
  WORKER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum WasteType {
  PET
  CARDBOARD
  PAPER
  METAL
  NON_RECYCLABLE
}

enum WasteCondition {
  proper
  mixed
  contaminated
}

enum RequestStatus {
  pending
  assigned
  collected
  verified
  paid
  cancelled
}

enum RouteType {
  recycling
  landfill
}

enum PriorityLevel {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TransactionStatus {
  pending
  authorized
  success
  failed
  refunded
}

enum TransactionType {
  cash
  bank
  wallet
}


model User {
  userId         Int      @id @default(autoincrement())
  email          String   @unique @db.VarChar(255)
  password       String   @db.VarChar(255)
  role           Role
  name           String   @db.VarChar(100)
  phone          String?  @db.VarChar(20)
  address        String?  @db.Text
  zoneId         Int?     // for workers
  vehicle        String?  @db.VarChar(50)  // for workers 
  status         UserStatus @default(ACTIVE)
  totalEarnings  Decimal    @default(0.0) @db.Decimal(12, 2)

  // Relations
  zone               Zone?            @relation(fields: [zoneId], references: [zoneId])
  pickupRequests     PickupRequest[]  @relation("citizenRequests")
  assignedPickups    PickupRequest[]  @relation("workerAssignments")
  transactions       Transaction[]
  createdRateConfigs RateConfig[]     @relation("adminCreatedRates")
  auditLogs          AuditLog[]

  // Timestamps & soft delete
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("users")
}

model Zone {
  zoneId      Int     @id @default(autoincrement())
  name        String  @unique @db.VarChar(100)
  description String? @db.Text
  city        String? @db.VarChar(20)
  isActive    Boolean @default(true)

  // Relations
  users  User[]
  routes Route[]

  // Soft delete & timestamps
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("zones")
}

model Route {
  routeId         Int      @id @default(autoincrement())
  name            String   @db.VarChar(100)
  type            RouteType
  zoneId          Int
  schedule        String?  @db.Text
  capacityPerDay  Int?
  isActive        Boolean  @default(true)

  // Relations
  zone           Zone            @relation(fields: [zoneId], references: [zoneId])
  pickupRequests PickupRequest[]

  // Soft delete & timestamps
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("routes")
}

model PickupRequest {
  requestId       Int            @id @default(autoincrement())
  citizenId       Int
  workerId        Int?
  routeId         Int?
  wasteType       WasteType
  estimatedWeight Decimal        @db.Decimal(8, 3)
  actualWeight    Decimal?       @db.Decimal(8, 3)
  condition       WasteCondition?
  status          RequestStatus  @default(pending)
  requestDate     DateTime       @default(now())
  assignedDate    DateTime?
  scheduledDate   DateTime?
  collectionDate  DateTime?
  priority        PriorityLevel  @default(MEDIUM)
  address         String         @db.Text
  notes           String?        @db.Text
  photoUrl        String?
  rateApplied     Decimal? @db.Decimal(10, 2) // snapshot of rate at verification

  // Relations
  citizen     User         @relation("citizenRequests", fields: [citizenId], references: [userId])
  worker      User?        @relation("workerAssignments", fields: [workerId], references: [userId])
  route       Route?       @relation(fields: [routeId], references: [routeId])
  transaction Transaction?

  // Soft delete & timestamps
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Indexes
  @@index([citizenId])
  @@index([workerId])
  @@index([routeId])
  @@index([status])
  @@index([requestDate])
  @@index([assignedDate])
  @@index([scheduledDate])
  @@index([priority])
  @@map("pickup_requests")
}

model Transaction {
  transactionId   Int            @id @default(autoincrement())
  citizenId       Int
  requestId       Int            @unique
  amount          Decimal        @db.Decimal(10, 2)
  rateApplied     Decimal        @db.Decimal(10, 2)
  weight          Decimal        @db.Decimal(10, 2)
  condition       WasteCondition
  transactionDate DateTime       @default(now())
  transactionStatus    TransactionStatus   @default(pending)
  payoutDate      DateTime?
  transactionType  TransactionType?

  // Relations
  citizen User          @relation(fields: [citizenId], references: [userId])
  request PickupRequest @relation(fields: [requestId], references: [requestId])

  // Soft delete & timestamps
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Indexes
  @@index([citizenId])
  @@index([transactionDate])
  @@index([transactionStatus])
  @@map("transactions")
}

model RateConfig {
  rateId        Int      @id @default(autoincrement())
  wasteType     WasteType
  condition     WasteCondition
  ratePerKg     Decimal  @db.Decimal(8, 3)
  effectiveFrom DateTime
  effectiveTo   DateTime?
  isActive      Boolean  @default(true)
  createdBy     Int

  // Relations
  creator User @relation("adminCreatedRates", fields: [createdBy], references: [userId])

  // Soft delete & timestamps
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Unique constraint
  @@unique([wasteType, condition, effectiveFrom])
  // Indexes
  @@index([isActive])
  @@index([createdBy])
  @@map("rate_configs")
}

model AuditLog {
  auditId    BigInt   @id @default(autoincrement())
  timestamp  DateTime @default(now())
  userId     Int
  userRole   Role
  action     String   @db.VarChar(20) // e.g. "ASSIGN_REQUEST", "VERIFY_WASTE"
  targetType String   @db.VarChar(20) // "REQUEST", "USER", "ROUTE", "TRANSACTION", "RATE_CONFIG"
  targetId   String?  @db.VarChar(20) // stored as string for flexibility
  details    String?  @db.VarChar(100)
  ipAddress  String?  @db.VarChar(50)

  // Relations
  user User @relation(fields: [userId], references: [userId])

  // Soft delete (rarely used)
  deletedAt DateTime?
  createdAt DateTime @default(now())

  // Indexes
  @@index([timestamp])
  @@index([userId])
  @@index([action])
  @@index([targetType])
  @@map("audit_logs")
}